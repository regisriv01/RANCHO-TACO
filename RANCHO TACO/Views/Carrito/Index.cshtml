@{
    ViewData["Title"] = "Carrito";
}

<link rel="stylesheet" href="~/css/site.css" />

<section class="carrito-container">

    <h2 class="titulo-carrito">🛒 Tu carrito</h2>

    <div id="carrito" class="carrito-grid"></div>

    <div class="carrito-footer">

        <h3>Total: $<span id="totalGeneral">0</span></h3>

        <div class="carrito-actions">
            <button class="btn-danger" onclick="vaciarCarrito()">Vaciar</button>
            <a href="/Pago" class="btn-primary-pro">Ir a pagar</a>
        </div>

    </div>

</section>

<script>
    function cargarCarrito() {

        let carrito = JSON.parse(sessionStorage.getItem("carrito")) || [];
        let contenedor = document.getElementById("carrito");

        contenedor.innerHTML = "";

        let total = 0;

        if (carrito.length === 0) {
            contenedor.innerHTML = `
                <div class="carrito-vacio">
                    <i class="fas fa-shopping-cart"></i>
                    <p>Tu carrito está vacío</p>
                </div>
            `;
            document.getElementById("totalGeneral").innerText = 0;
            return;
        }

        carrito.forEach((p, index) => {

            total += parseInt(p.precio);

            let card = document.createElement("div");
            card.className = "item-carrito card";

            card.innerHTML = `
                <div class="item-header">
                    <h4>${p.nombre}</h4>
                    <span class="precio">$${p.precio}</span>
                </div>

                <div class="item-body">
                    <p><strong>Ingredientes:</strong> ${p.ingredientes.join(", ")}</p>
                    <p><strong>Extras:</strong> ${p.extras.join(", ") || "Ninguno"}</p>
                </div>

                <button class="btn-remove" data-index="${index}">
                    <i class="fas fa-trash"></i> Eliminar
                </button>
            `;

            contenedor.appendChild(card);
        });

        document.getElementById("totalGeneral").innerText = total;

        // eventos eliminar
        document.querySelectorAll(".btn-remove").forEach(btn => {
            btn.addEventListener("click", () => eliminar(btn.dataset.index));
        });
    }

    // ELIMINAR
    function eliminar(index) {
        let carrito = JSON.parse(sessionStorage.getItem("carrito")) || [];

        carrito.splice(index, 1);
        sessionStorage.setItem("carrito", JSON.stringify(carrito));

        cargarCarrito();
    }

    // VACIAR
    function vaciarCarrito() {
        sessionStorage.removeItem("carrito");
        cargarCarrito();
    }

    // INIT
    document.addEventListener("DOMContentLoaded", cargarCarrito);
</script>